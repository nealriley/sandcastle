# Sandcastle middleware example environment.
# Copy to .env.local for local development.

PUBLIC_APP_URL=http://localhost:3000

# Pack / control-plane auth
AGENT_API_KEY=replace-me

# Anthropic upstream
ANTHROPIC_API_KEY=replace-me

# Token signing
CONTROL_TOKEN_SECRET=replace-me
# Optional overrides:
# SESSION_TOKEN_SECRET=
# TASK_TOKEN_SECRET=
# VIEW_TOKEN_SECRET=
# ANTHROPIC_PROXY_TOKEN_SECRET=

# Website auth
AUTH_SECRET=replace-me
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me

# Redis / Upstash
UPSTASH_REDIS_REST_URL=replace-me
UPSTASH_REDIS_REST_TOKEN=replace-me
# Marketplace aliases also work:
# KV_URL=
# KV_REST_API_TOKEN=
# REDIS_URL=

# Optional snapshot acceleration
# BASE_SNAPSHOT_ID=

# Optional smoke-test override
# SANDCASTLE_BASE_URL=http://localhost:3000
